{% extends 'base.html.twig' %}

{% block title %}Cancel Membership - Artlet{% endblock %}

{% block content %}

<div style="max-width:500px; margin:50px auto; text-align:center; border:1px solid #ddd; padding:20px; border-radius:10px; background:white;">

    <h2>Cancel Premium Plan?</h2>

    <p style="color:#666;">
        You are about to switch back to the Free plan.
        You will lose premium features immediately.
    </p>

    <div style="margin-top:20px; display:flex; gap:10px; justify-content:center;">

        <a href="{{ basePath }}/membership"
           style="padding:10px 15px; background:#ccc; border-radius:5px; text-decoration:none; color:black;">
            Go Back
        </a>

        <form method="POST" action="{{ basePath }}/membership/cancel">
            <button type="submit"
                    style="padding:10px 15px; background:red; color:white; border:none; border-radius:5px;">
                Yes, Cancel Plan
            </button>
        </form>

    </div>

</div>

{% endblock %}