{% extends 'base.html.twig' %}

{% block title %}{{ art.title }} - Artlet{% endblock %}

{% block content %}

<div style="padding:30px; max-width:1000px; margin:auto;">

    <div style="
        display:flex;
        border:1px solid #ddd;
        border-radius:10px;
        overflow:hidden;
        background:white;
    ">

        <div style="flex:1;">
            <img src="{{ basePath }}/assets/placeholder.png"
                 alt="art image"
                 style="width:100%; height:100%; object-fit:cover;">
        </div>

        <div style="flex:1; display:flex; flex-direction:column;">

            <div style="flex:1; padding:15px; border-bottom:1px solid #eee;">

                <h2 style="margin:0;">{{ art.title }}</h2>

                <p style="margin:5px 0; color:#666;">
                    by 
                    <a href="{{ basePath }}/user/{{ art.artist }}"
                    style="color:orchid; text-decoration:none;">
                        {{ art.artist ?? 'Unknown Artist' }}
                    </a>
                </p>

                <a href="{{ basePath }}/download/{{ art.id }}"
                   style="
                        display:inline-block;
                        margin-top:10px;
                        padding:8px 12px;
                        background:orchid;
                        color:white;
                        text-decoration:none;
                        border-radius:5px;
                   ">
                    Download
                </a>

            </div>

            <div style="flex:2; padding:15px; overflow:auto;">

                <h4>Description</h4>

                <p style="color:#444; line-height:1.5;">
                    {{ art.description }}
                </p>

            </div>

        </div>

    </div>

    <div style="margin-top:30px;">

        <h3>Comments</h3>

        {% if comments is empty %}
            <p style="color:#666;">No comments yet.</p>
        {% else %}
            {% for comment in comments %}
                <div style="
                    border:1px solid #eee;
                    padding:10px;
                    margin-bottom:10px;
                    border-radius:8px;
                    background:#fafafa;
                    position:relative;
                ">

                    <form method="POST"
                        action="{{ basePath }}/comment/{{ comment.id }}/delete"
                        style="
                            position:absolute;
                            top:8px;
                            right:8px;
                            margin:0;
                        ">

                        <button type="submit"
                                style="
                                    background:red;
                                    color:white;
                                    border:none;
                                    border-radius:4px;
                                    padding:4px 8px;
                                    cursor:pointer;
                                    font-size:12px;
                                ">
                            🗑️
                        </button>

                    </form>

                    <strong>{{ comment.username }}</strong>
                    <p style="margin:5px 0;">{{ comment.content }}</p>

                </div>
            {% endfor %}
        {% endif %}

        <form method="POST"
              action="{{ basePath }}/art/{{ art.id }}/comment"
              style="margin-top:15px;">

            <textarea name="content"
                      required
                      placeholder="Write a comment..."
                      style="width:100%; height:80px; padding:10px;"></textarea>

            <button type="submit"
                    style="
                        margin-top:10px;
                        padding:10px 15px;
                        background:#333;
                        color:white;
                        border:none;
                        border-radius:5px;
                    ">
                Post Comment
            </button>

        </form>

    </div>

</div>

{% endblock %}